# Server
PORT=5001
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/studybox-ai
# Or for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/studybox-ai?retryWrites=true&w=majority

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this_in_production

# CORS
FRONTEND_URL=http://localhost:5173
# For production: FRONTEND_URL=https://yourdomain.com

# API Configuration
API_VERSION=v2
